# Django
DJANGO_SECRET_KEY=unsafe-dev-key-change-in-prod
DJANGO_SETTINGS_MODULE=config.settings.dev
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_HOST=db
DB_NAME=tecker
DB_USER=tecker
DB_PASSWORD=tecker
DB_PORT=3306

# Redis
REDIS_URL=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0

# Google OAuth  ← Google Cloud Console에서 플랫폼별로 각각 발급
# 애플리케이션 유형: iOS → iOS 클라이언트 ID
#                  Android → Android 클라이언트 ID
# 쉼표로 구분해서 둘 다 입력 (또는 사용하는 플랫폼만)
GOOGLE_CLIENT_IDS=ios-client-id.apps.googleusercontent.com,android-client-id.apps.googleusercontent.com

# Google Cloud Console → 사용자 인증 정보 → iOS/Android 클라이언트 보안 비밀번호
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AWS Rekognition
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=ap-northeast-2
REKOGNITION_COLLECTION_ID=tecker-faces

# Anti-Spoofing 서버 (Flask 마이크로서비스)
AI_SERVER_URL=http://antispoof:5001

# QR 코드에 인코딩할 베이스 URL
API_BASE_URL=http://localhost:8000
