{
  "uid": "tecker-booking",
  "title": "Booking",
  "tags": ["tecker"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Booking Attempts by Result",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(booking_attempts_total[5m])",
          "legendFormat": "{{result}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Booking Latency P50/P95/P99",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(booking_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(booking_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(booking_latency_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "title": "Booking Success Rate",
      "type": "stat",
      "gridPos": {"x": 0, "y": 8, "w": 6, "h": 4},
      "targets": [
        {
          "expr": "rate(booking_attempts_total{result=\"success\"}[5m]) / rate(booking_attempts_total[5m])",
          "legendFormat": "success rate"
        }
      ]
    }
  ]
}
