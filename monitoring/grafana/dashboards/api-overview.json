{
  "uid": "tecker-api-overview",
  "title": "API Overview",
  "tags": ["tecker"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(django_http_requests_latency_seconds_count[1m])) by (view)",
          "legendFormat": "{{view}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "P95 Latency (s)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(django_http_requests_latency_seconds_bucket[5m])) by (le, view))",
          "legendFormat": "p95 {{view}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "5xx Error Rate",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "sum(rate(django_http_responses_total_by_status_total{status=~\"5..\"}[5m]))",
          "legendFormat": "5xx/s"
        }
      ]
    },
    {
      "id": 4,
      "title": "Cache Hit Ratio",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "targets": [
        {
          "expr": "rate(cache_hits_total{result=\"hit\"}[5m]) / rate(cache_hits_total[5m])",
          "legendFormat": "hit ratio {{cache}}"
        }
      ]
    }
  ]
}
